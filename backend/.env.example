# HeatAI 环境变量配置模板
# 复制此文件为 .env 并修改配置

SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL (默认)
DATABASE_URL=postgresql+asyncpg://heatai:your_password@localhost:5432/heatai
DATABASE_URL_SYNC=postgresql+psycopg2://heatai:your_password@localhost:5432/heatai

# SQLite (开发备选，取消注释并注释上面两行)
# DATABASE_URL=sqlite+aiosqlite:///./heatai.db
# DATABASE_URL_SYNC=sqlite+pysqlite:///./heatai.db

# Redis (可选)
REDIS_URL=redis://localhost:6379/0

# CORS 允许的源
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
